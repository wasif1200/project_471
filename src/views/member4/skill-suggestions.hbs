<section class="container-fluid app-container">
  <div class="d-flex flex-wrap justify-content-between align-items-end gap-3 mb-4">
    <div>
      <div class="page-kicker mb-2">Module 3 Feature 7</div>
      <h1 class="page-title h1 text-gradient mb-2">Personalized Skill Suggestions</h1>
      <p class="page-lead mb-0">Find score-based skill gaps, recommended courses, and track course progress in one shared UI.</p>
    </div>
    <a class="btn btn-outline-light" href="/member4">Back to Dashboard</a>
  </div>

  <div class="app-card p-4 mb-4">
    <div class="row g-3 align-items-end">
      <div class="col-md-3">
        <label class="form-label">Student ID</label>
        <input class="form-control" type="number" id="ssStudentId" value="1" min="1" />
      </div>
      <div class="col-md-3">
        <label class="form-label">Internship ID (optional)</label>
        <input class="form-control" type="number" id="ssInternshipId" placeholder="1, 2, or 3" min="1" />
      </div>
      <div class="col-md-3 d-grid">
        <button class="btn btn-primary" id="ssAnalyzeBtn"><i class="bi bi-mortarboard"></i> Analyze Suggestions</button>
      </div>
      <div class="col-md-3 d-grid">
        <button class="btn btn-outline-light" id="ssHistoryBtn"><i class="bi bi-clock-history"></i> Course History</button>
      </div>
    </div>
    <div class="text-soft small mt-3">Demo combinations: Student 1 + Internship 1, Student 2 + Internship 2, Student 3 + Internship 3.</div>
  </div>

  <div id="ssSummary" class="row g-3 mb-4 d-none"></div>
  <div id="ssContent" class="app-card p-5 text-center text-soft">Enter a student ID and click Analyze Suggestions.</div>
</section>

<div class="modal fade" id="completeCourseModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content bg-dark text-light border-secondary rounded-4">
      <div class="modal-header border-secondary">
        <h5 class="modal-title">Confirm course completion</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <p class="text-soft mb-0">Mark <strong id="ssModalCourseName"></strong> as completed and update your skill score?</p>
      </div>
      <div class="modal-footer border-secondary">
        <button class="btn btn-outline-light" data-bs-dismiss="modal">Cancel</button>
        <button class="btn btn-primary" id="ssConfirmComplete">Yes, Complete</button>
      </div>
    </div>
  </div>
</div>

<script src="/member4/js/skill-suggestions.js"></script>

<section class="container-fluid app-container">
  <div class="d-flex flex-wrap justify-content-between align-items-end gap-3 mb-4">
    <div>
      <div class="page-kicker mb-2">Module 1 Feature 4</div>
      <h1 class="page-title h1 text-gradient mb-2">Skill Gap Dashboard</h1>
      <p class="page-lead mb-0">Select a demo student and internship to compare current skills with required skills.</p>
    </div>
    <a class="btn btn-outline-light" href="/member4">Back to Dashboard</a>
  </div>

  <div class="app-card p-4 mb-4">
    <div class="row g-3 align-items-end">
      <div class="col-md-3">
        <label class="form-label">Student ID</label>
        <input class="form-control" type="number" id="sgStudentId" value="1" min="1" />
      </div>
      <div class="col-md-6">
        <label class="form-label">Internship</label>
        <select class="form-select" id="sgInternship"></select>
      </div>

    <div class="col-md-2">
        <label class="form-label">cgpa</label>
        <select class="form-select" id="sgcgpa"></select>
      </div>


           
      <div class="col-md-3 d-grid">
        <button class="btn btn-primary" id="sgAnalyzeBtn"><i class="bi bi-search"></i> Analyze Gap</button>
      </div>
    </div>
    <div class="text-soft small mt-3">Tip: seed data includes Student IDs 1, 2, and 3.</div>
  </div>

  <div id="sgState" class="app-card p-5 text-center text-soft">Loading internships...</div>

  <div id="sgResults" class="d-none">
    <div class="app-card p-4 mb-4">
      <div class="row g-4 align-items-center">
        <div class="col-lg-8">
          <div class="text-soft small">Student</div>
          <h2 class="h4 fw-bold mb-1" id="sgStudentName"></h2>
          <div class="text-soft" id="sgInternshipTitle"></div>
        </div>
        <div class="col-lg-4 text-lg-end">
          <div class="display-5 fw-bold text-gradient" id="sgReadiness"></div>
          <div class="text-soft">Readiness Score</div>
        </div>
      </div>
    </div>

    <div class="row g-3 mb-4" id="sgStats"></div>

    <div class="row g-4 mb-4">
      <div class="col-lg-7">
        <div class="app-card p-4 h-100">
          <h3 class="h5 fw-bold mb-3">Skill Level Comparison</h3>
          <canvas id="sgBarChart" height="150"></canvas>
        </div>
      </div>
      <div class="col-lg-5">
        <div class="app-card p-4 h-100">
          <h3 class="h5 fw-bold mb-3">Skill Status</h3>
          <canvas id="sgDoughnutChart" height="170"></canvas>
        </div>
      </div>
    </div>

    <div class="app-card p-4 mb-4">
      <h3 class="h5 fw-bold mb-3">Detailed Skill Gap</h3>
      <div class="table-responsive">
        <table class="table table-hover align-middle">
          <thead><tr><th>Skill</th><th>Category</th><th>Your Level</th><th>Required</th><th>Status</th></tr></thead>
          <tbody id="sgSkillRows"></tbody>
        </table>
      </div>
    </div>

  </div>
</section>

<script src="/member4/js/skill-gap.js"></script>

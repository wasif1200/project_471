<section class="container-fluid app-container">
  <div class="d-flex flex-wrap justify-content-between align-items-end gap-3 mb-4">
    <div>
      <div class="page-kicker mb-2">Module 3 Feature 8</div>
      <h1 class="page-title h1 text-gradient mb-2">AI Chatbot Assistant</h1>
      <p class="page-lead mb-0">Ask for resume help, internship search advice, course suggestions, skill tracking, or a study plan.</p>
    </div>
    <a class="btn btn-outline-light" href="/member4">Back to Dashboard</a>
  </div>

  <div class="row g-4">
    <div class="col-lg-4">
      <div class="app-card p-4 mb-4">
        <label class="form-label">Student ID</label>
        <div class="input-group">
          <input class="form-control" id="chatStudentId" type="number" value="1" min="1" />
          <button class="btn btn-primary" id="loadProfileBtn">Load</button>
        </div>
        <div class="text-soft small mt-2">Try demo IDs 1, 2, or 3.</div>
      </div>

      <div class="app-card p-4 mb-4" id="chatProfile">
        <div class="text-soft">Load a profile to see student context.</div>
      </div>

      <div class="app-card p-4">
        <h2 class="h6 fw-bold mb-3">Quick Actions</h2>
        <div class="d-flex flex-column gap-2" id="quickActions">
          <button class="btn btn-sm btn-outline-light text-start quick-action">Show my profile summary</button>
          <button class="btn btn-sm btn-outline-light text-start quick-action">Suggest courses for my skills</button>
          <button class="btn btn-sm btn-outline-light text-start quick-action">Find internships that match me</button>
          <button class="btn btn-sm btn-outline-light text-start quick-action">Make me a 7-day study plan</button>
        </div>
      </div>
    </div>

    <div class="col-lg-8">
      <div class="app-card p-4">
        <div class="d-flex flex-wrap justify-content-between gap-2 align-items-center mb-3">
          <h2 class="h5 fw-bold mb-0">Chat</h2>
          <button class="btn btn-sm btn-outline-light" id="clearChatBtn"><i class="bi bi-trash"></i> Clear History</button>
        </div>
        <div class="chat-window" id="chatWindow">
          <div class="chat-message chat-bot">Hi! I am your Internship & Skill Assistant. Load a demo student and ask me anything about skills, internships, courses, resumes, or study plans.</div>
        </div>
        <div id="chatCards" class="mt-3"></div>
        <form class="d-flex gap-2 mt-3" id="chatForm">
          <input class="form-control" id="chatInput" placeholder="Ask: Suggest courses for my skills" autocomplete="off" />
          <button class="btn btn-primary" type="submit">Send</button>
        </form>
      </div>
    </div>
  </div>
</section>

<script src="/member4/js/chatbot.js"></script>

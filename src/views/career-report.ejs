<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="page-wrapper">
    <div class="topbar">
      <div class="logo">✦ Riza.</div>

      <div class="nav-pill">
        <a href="/">HOME</a>
        <a href="/student/internships">EXPLORE INTERNSHIPS</a>
        <a href="/student/recommendations">RECOMMENDATIONS</a>
        <a href="/student/dashboard">PROFILE</a>
        <a href="/student/career-report" class="active">CAREER REPORT</a>
      </div>
    </div>

    <div class="home-hero" style="padding: 40px 0 10px 0; min-height: auto;">
      <div class="home-hero-content">
        <h1 class="hero-title">Student Career Report</h1>
        <p class="hero-subtitle">
          A personalized summary of your skills, experience, internship fit, and skill gaps.
        </p>

        <div style="margin-top: 20px; display:flex; justify-content:center; gap:20px; flex-wrap:wrap;">
          <a href="/student/career-report/pdf"
             style="
                padding:10px 22px;
                border-radius:25px;
                background: rgba(255,255,255,0.12);
                color:#fff;
                font-weight:600;
                text-decoration:none;
                backdrop-filter: blur(6px);
                border:1px solid rgba(255,255,255,0.15);
                box-shadow: 0 0 10px rgba(255,255,255,0.2);
                transition: all 0.3s ease;
             "
             onmouseover="this.style.background='rgba(255,255,255,0.25)'"
             onmouseout="this.style.background='rgba(255,255,255,0.12)'">
            📄 Download PDF
          </a>

          <a href="/student/career-report/csv"
             style="
               padding:10px 22px;
               border-radius:25px;
               background: rgba(0,255,150,0.15);
               color:#fff;
               font-weight:600;
               text-decoration:none;
               backdrop-filter: blur(6px);
               border:1px solid rgba(0,255,150,0.3);
               transition: all 0.3s ease;
            "
            onmouseover="this.style.background='rgba(0,255,150,0.3)'"
            onmouseout="this.style.background='rgba(0,255,150,0.15)'">
            📊 Download CSV
          </a>
        </div>
      </div>
    </div>

    <h2 class="section-title">Basic Information</h2>
    <div class="glass-card" style="padding: 24px; margin-bottom: 24px;">
      <p><strong>Name:</strong> <%= student.firstName %> <%= student.lastName %></p>
      <p><strong>Email:</strong> <%= student.email %></p>
      <p><strong>Department:</strong> <%= student.department || 'N/A' %></p>
      <p><strong>Degree:</strong> <%= student.degree || 'N/A' %></p>
      <p><strong>Sector Preferences:</strong> <%= student.sectorPreferences || 'N/A' %></p>
      <p><strong>Location Preferences:</strong> <%= student.locationPreferences || 'N/A' %></p>
    </div>

    <h2 class="section-title">Skills</h2>
    <div class="glass-card" style="padding: 24px; margin-bottom: 24px;">
      <% if (student.skills && student.skills.length > 0) { %>
        <div style="display:flex; flex-wrap:wrap; gap:10px;">
          <% student.skills.forEach(skill => { %>
            <span style="
              padding:6px 14px;
              border-radius:20px;
              background: rgba(255,255,255,0.12);
              color:#fff;
              font-size:13px;
              backdrop-filter: blur(6px);
            ">
              <%= skill.name %>
            </span>
          <% }) %>
        </div>
      <% } else { %>
        <p>No skills added yet.</p>
      <% } %>
    </div>

    <h2 class="section-title">Experience</h2>
    <div class="glass-card" style="padding: 24px; margin-bottom: 24px;">
      <p><%= student.experience || 'No experience information added yet.' %></p>
    </div>

    <h2 class="section-title">Certificate & Practical Experience</h2>
    <div class="glass-card" style="padding: 24px; margin-bottom: 24px;">
      <% if (certificate) { %>
        <div class="mb-2">
          <strong>Company:</strong>
          <span><%= certificate.companyName || 'N/A' %></span>
        </div>

        <div class="mb-3">
          <strong>Internship Duration:</strong>
          <span><%= certificate.durationMonths || 'N/A' %> month(s)</span>
        </div>

        <div class="mb-3">
          <strong>Rating:</strong>
          <div class="stars" style="margin-top: 8px; font-size: 20px;">
            <% for (let i = 1; i <= 5; i++) { %>
              <% if (i <= certificate.experienceRating) { %>
                <span style="color: gold;">★</span>
              <% } else { %>
                <span class="empty-star" style="color: #ccc;">☆</span>
              <% } %>
            <% } %>
          </div>
        </div>

        <div style="margin-top: 16px;">
          <a href="/certificates/view/<%= certificate.id %>" target="_blank" class="nav-btn-blue">
            View Certificate
          </a>
        </div>
      <% } else { %>
        <p>No certificate information added yet.</p>

        <a href="/certificates" class="nav-btn-blue">
          Add Certificate
        </a>
      <% } %>
    </div>

    <h2 class="section-title">Recommended Internships</h2>
    <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; margin-bottom: 32px;">
      <% if (recommendedInternships && recommendedInternships.length > 0) { %>
        <% recommendedInternships.forEach(internship => { %>
          <div class="glass-card" style="padding: 22px;">
            <h3 style="margin-bottom: 10px;"><%= internship.title %></h3>
            <p style="opacity: 0.85; margin-bottom: 8px;"><%= internship.company %></p>
            <p style="margin-bottom: 8px;"><strong>Location:</strong> <%= internship.location %></p>
            <p style="margin-bottom: 8px;"><strong>Work Mode:</strong> <%= internship.workMode %></p>
            <p style="margin-bottom: 0;"><strong>Match:</strong> <%= internship.matchPercentage %>%</p>
          </div>
        <% }) %>
      <% } else { %>
        <div class="glass-card" style="padding: 24px;">
          <p style="margin: 0;">No platform recommendations available right now.</p>
        </div>
      <% } %>
    </div>

    <h2 class="section-title">External Opportunities</h2>
    <p class="section-subtitle">
      Live external opportunities matched with your skills.
    </p>

    <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px; margin-bottom: 40px;">
      <% if (externalRecommendations && externalRecommendations.length > 0) { %>
        <% externalRecommendations.forEach(job => { %>
          <div class="glass-card" style="padding: 22px;">
            <h3 style="margin-bottom: 10px;"><%= job.title %></h3>
            <p style="opacity: 0.85; margin-bottom: 12px;"><%= job.company %></p>

            <p><strong>Location:</strong> <%= job.location %></p>
            <p><strong>Mode:</strong> <%= job.workMode %></p>
            <p><strong>Match:</strong> <%= job.matchPercentage %>%</p>
            <p><strong>Matched Skills:</strong>
              <%= job.matchedSkills.length ? job.matchedSkills.join(', ') : 'None' %>
            </p>

            <% if (job.applyLink) { %>
              <a href="<%= job.applyLink %>" target="_blank" class="nav-btn-blue">
                Apply Now
              </a>
            <% } %>
          </div>
        <% }) %>
      <% } else { %>
        <div class="glass-card" style="padding: 24px;">
          <p style="margin: 0;">No external opportunities available right now.</p>
        </div>
      <% } %>
    </div>

    <h2 class="section-title">Skill Gap Analysis</h2>
    <p class="section-subtitle">
      Compare your current skills with the requirements of top platform internships.
    </p>

    <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px; margin-bottom: 40px;">
      <% if (analyzedInternships && analyzedInternships.length > 0) { %>
        <% analyzedInternships.forEach(internship => { %>
          <div class="glass-card" style="padding: 22px;">
            <h3 style="margin-bottom: 10px;"><%= internship.title %></h3>
            <p style="opacity: 0.85; margin-bottom: 12px;"><%= internship.company %></p>

            <p><strong>Required Skills:</strong>
              <%= internship.requiredSkills.length ? internship.requiredSkills.join(', ') : 'N/A' %>
            </p>

            <p><strong>Matched Skills:</strong>
              <%= internship.matchedSkills.length ? internship.matchedSkills.join(', ') : 'None' %>
            </p>

            <p><strong>Missing Skills:</strong>
              <%= internship.missingSkills.length ? internship.missingSkills.join(', ') : 'None' %>
            </p>

            <p><strong>Match Percentage:</strong> <%= internship.matchPercentage %>%</p>
          </div>
        <% }) %>
      <% } else { %>
        <div class="glass-card" style="padding: 24px;">
          <p style="margin: 0;">
            No platform internships available yet, so skill gap analysis cannot be generated right now.
          </p>
        </div>
      <% } %>
    </div>
  </div>
</body>
</html>
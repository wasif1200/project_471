<%- include('partials/header') %>
<div class="container py-4">
  <h1>Available Internships</h1>
  <% if (typeof internships !== 'undefined' && internships.length) { %>
    <div class="row g-3"><% internships.forEach(i => { %><div class="col-md-6"><div class="card p-3 h-100"><h5><%= i.title %></h5><p><%= i.location || 'Location not specified' %> · <%= i.workMode || '' %></p><a href="/company/internships/student/<%= i.id %>" class="btn btn-sm btn-primary">View Details</a></div></div><% }) %></div>
  <% } else { %><p>No internships found.</p><% } %>
</div>
<%- include('partials/footer') %>

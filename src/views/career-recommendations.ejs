<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="page-wrapper">
    <div class="topbar">
      <div class="logo">✦ Riza.</div>

      <div class="nav-pill">
        <a href="/">HOME</a>
        <a href="/student/internships">EXPLORE INTERNSHIPS</a>
        <a href="#">MY APPLICATIONS</a>
        <a href="/certificates">ADD CERTIFICATE</a>
        <a href="/student/dashboard">PROFILE</a>
        <a href="/student/recommendations" class="active">RECOMMENDATIONS</a>
      </div>
    </div>

    <div class="home-hero" style="padding: 60px 0 20px 0; min-height: auto;">
      <div class="home-hero-content">
        <h1 class="hero-title">Recommended Internships</h1>
        <p class="hero-subtitle">
          Discover internship opportunities matched with your skills, preferences, and profile.
        </p>
      </div>
    </div>

    <h2 class="section-title" style="margin-top: 10px;">Platform Internships</h2>
    <p class="section-subtitle">
      Internships posted on the platform based on your profile match.
    </p>

    <% if (!internalRecommendations.length) { %>
      <div class="glass-card" style="padding: 18px; margin-bottom: 24px;">
        <p style="margin: 0;">No platform internships found.</p>
      </div>
    <% } %>

    <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; margin-bottom: 40px;">
      <% internalRecommendations.forEach(internship => { %>
        <div class="glass-card" style="padding: 22px;">
          <h3 style="margin-bottom: 10px;"><%= internship.title %></h3>
          <p style="opacity: 0.85; margin-bottom: 8px;">
            <%= internship.company ? internship.company.companyName : 'Unknown Company' %>
          </p>

          <div style="display:flex; gap: 12px; flex-wrap: wrap; font-size: 14px; margin-bottom: 12px;">
            <span><%= internship.location || 'N/A' %></span>
            <span><%= internship.workMode || 'N/A' %></span>
          </div>

          <div style="margin-bottom: 12px;">
            <span class="skill-badge">Match: <%= internship.matchPercentage %>%</span>
          </div>

          <div style="margin-bottom: 12px;">
            <% if (internship.matchedSkills.length) { %>
              <% internship.matchedSkills.forEach(skill => { %>
                <span class="skill-badge"><%= skill %></span>
              <% }) %>
            <% } else { %>
              <span style="opacity: 0.7;">No matched skills</span>
            <% } %>
          </div>

          <p style="font-size: 14px; margin-bottom: 16px;">
            <strong>Missing Skills:</strong>
            <%= internship.missingSkills.length ? internship.missingSkills.join(', ') : 'None' %>
          </p>

          <div style="display:flex; gap: 12px;">
            <a href="/student/internships/<%= internship.id %>" class="btn-light-pill">View Details</a>
          </div>
        </div>
      <% }) %>
    </div>

    <h2 class="section-title">External Opportunities</h2>
    <p class="section-subtitle">
      Live external internship and job opportunities related to your profile.
    </p>

    <% if (!externalRecommendations.length) { %>
      <div class="glass-card" style="padding: 18px; margin-bottom: 24px;">
        <p style="margin: 0;">No external opportunities found.</p>
      </div>
    <% } %>

    <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px;">
      <% externalRecommendations.forEach(job => { %>
        <div class="glass-card" style="padding: 22px;">
          <h3 style="margin-bottom: 10px;"><%= job.title || 'Untitled Opportunity' %></h3>
          <p style="opacity: 0.85; margin-bottom: 8px;">
            <%= job.company_name || 'Unknown Company' %>
          </p>

          <div style="display:flex; gap: 12px; flex-wrap: wrap; font-size: 14px; margin-bottom: 12px;">
            <span><%= job.location || 'N/A' %></span>
            <span><%= job.remote ? 'Remote' : 'On-site' %></span>
          </div>

          <div style="margin-bottom: 12px;">
            <span class="skill-badge">Match: <%= job.matchPercentage %>%</span>
          </div>

          <div style="margin-bottom: 16px;">
            <% if (job.matchedSkills.length) { %>
              <% job.matchedSkills.forEach(skill => { %>
                <span class="skill-badge"><%= skill %></span>
              <% }) %>
            <% } else { %>
              <span style="opacity: 0.7;">No matched skills</span>
            <% } %>
          </div>

          <div style="display:flex; gap: 12px;">
            <% if (job.url) { %>
              <a href="<%= job.url %>" target="_blank" class="btn-primary-glow">Apply Now</a>
            <% } %>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</body>
</html>
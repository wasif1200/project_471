<%- include('partials/header') %>

<div class="portal-bg">
  <div class="portal-overlay"></div>

  <div class="container py-4">
    <%- include('partials/alerts') %>

    <div class="portal-page-wrap">
      <div class="portal-page-heading text-center mb-4">
        <h1 class="portal-main-title">Edit Internship</h1>
        <p class="portal-main-subtitle">Update your internship posting details.</p>
      </div>

      <div class="register-shell">
        <form action="/company/internships/edit/<%= internship.id %>?_method=PUT" method="POST">
          <div class="section-glass mb-4">
            <div class="row g-4">
              <div class="col-md-6">
                <label class="custom-label">Role Title</label>
                <input type="text" name="title" value="<%= internship.title %>" class="form-control custom-input" required>
              </div>

              <div class="col-md-6">
                <label class="custom-label">Department</label>
                <input type="text" name="department" value="<%= internship.department || '' %>" class="form-control custom-input">
              </div>

              <div class="col-md-6">
                <label class="custom-label">Location</label>
                <input type="text" name="location" value="<%= internship.location || '' %>" class="form-control custom-input">
              </div>

              <div class="col-md-6">
                <label class="custom-label">Work Mode</label>
                <input type="text" name="workMode" value="<%= internship.workMode || '' %>" class="form-control custom-input">
              </div>

              <div class="col-md-6">
                <label class="custom-label">Duration</label>
                <input type="number" name="durationMonths" value="<%= internship.durationMonths || '' %>" class="form-control custom-input">
              </div>

              <div class="col-md-6">
                <label class="custom-label">Stipend</label>
                <input type="number" step="0.01" name="stipend" value="<%= internship.stipend || '' %>" class="form-control custom-input">
              </div>

              <div class="col-12">
                <label class="custom-label">Role Description</label>
                <textarea name="roleDescription" class="form-control custom-textarea" required><%= internship.roleDescription %></textarea>
              </div>

              <div class="col-12">
                <label class="custom-label">Learning Outcomes</label>
                <textarea name="learningOutcomes" class="form-control custom-textarea"><%= internship.learningOutcomes || '' %></textarea>
              </div>

              <div class="col-md-6">
                <label class="custom-label">Number of Positions</label>
                <input type="number" name="numberOfPositions" value="<%= internship.numberOfPositions || 1 %>" class="form-control custom-input">
              </div>

              <div class="col-md-6">
                <label class="custom-label">Required Skills</label>
                <input type="text" name="requiredSkills" value="<%= internship.requiredSkills || '' %>" class="form-control custom-input">
              </div>

              <div class="col-md-6">
                <label class="custom-label">Minimum Degree</label>
                <input type="text" name="minimumDegreeLevel" value="<%= internship.minimumDegreeLevel || '' %>" class="form-control custom-input">
              </div>

              <div class="col-md-6">
                <label class="custom-label">Preferred Field</label>
                <input type="text" name="preferredFieldOfStudy" value="<%= internship.preferredFieldOfStudy || '' %>" class="form-control custom-input">
              </div>

              <div class="col-md-6">
                <label class="custom-label">Minimum GPA</label>
                <input type="text" name="minimumGpaPercentage" value="<%= internship.minimumGpaPercentage || '' %>" class="form-control custom-input">
              </div>

              <div class="col-md-6">
                <label class="custom-label">Graduation Year Range</label>
                <input type="text" name="graduationYearRange" value="<%= internship.graduationYearRange || '' %>" class="form-control custom-input">
              </div>
              <div class="mb-3">
                <label class="form-label">Application Deadline</label>
                <input
                  type="date"
                  name="applicationDeadline"
                  class="form-control"
                  value="<%= internship.applicationDeadline ? new Date(internship.applicationDeadline).toISOString().split('T')[0] : '' %>"
                >
              </div>

              <div class="col-12">
                <label class="custom-label">Additional Preferences</label>
                <textarea name="additionalPreferences" class="form-control custom-textarea"><%= internship.additionalPreferences || '' %></textarea>
              </div>
            </div>
          </div>

          <div class="step-action-between">
            <a href="/company/internships/manage" class="glass-btn">Back</a>
            <button type="submit" class="nav-btn-blue border-0">Update Internship</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
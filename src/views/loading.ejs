<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Generating Rating</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="loading-screen">
    <div class="glass-card loading-panel">
      <h1>Rating<br>Calculating<br>Automatically</h1>

      <p>
        Please Wait While the Practical Experience Rating
        is Generated for Your Internship Certificate
        <span class="spinner-ring"></span>
      </p>
    </div>
  </div>

  <script>
    setTimeout(() => {
      window.location.href = "<%= redirectUrl %>";
    }, 2000);
  </script>
</body>
</html>
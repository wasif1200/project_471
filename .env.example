# Vercel/production database. Use Prisma Postgres, Neon, Supabase, Railway, etc.
# Do NOT use file:./dev.db on Vercel.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

PORT=3000
SESSION_SECRET="replace_with_a_long_random_secret"

# Optional: used only by the Member 4 chatbot if you want AI answers
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-3.5-turbo"

# Local only: keep deadline cron on by default locally.
# Set false if you do not want the local cron job to run.
ENABLE_DEADLINE_JOB="true"
